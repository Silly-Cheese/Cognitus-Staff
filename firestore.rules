rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function empPath(id) { return /databases/$(database)/documents/employees/$(id); }
    function emp(id) { return get(empPath(id)).data; }
    function existsEmp(id) { return exists(empPath(id)); }
    function hasSession(id) {
      return existsEmp(id)
        && (
          emp(id).authUid == request.auth.uid
          || (emp(id).authUids is list && request.auth.uid in emp(id).authUids)
        );
    }
    function active(id) {
      return signedIn() && existsEmp(id) && hasSession(id) && emp(id).status in ['Active', 'Training', 'On Leave'];
    }
    function atLeast(id, required) { return active(id) && emp(id).accessLevel >= required; }
    function actorAtLeast(required) {
      return signedIn()
        && request.resource.data.updatedByEmployeeId is string
        && atLeast(request.resource.data.updatedByEmployeeId, required);
    }
    function creatorAtLeast(required) {
      return signedIn()
        && request.resource.data.createdBy is string
        && atLeast(request.resource.data.createdBy, required);
    }
    function loginClaim() {
      return signedIn()
        && request.resource.data.employeeId == resource.data.employeeId
        && request.resource.data.discordUsername == resource.data.discordUsername
        && request.resource.data.accessLevel == resource.data.accessLevel
        && request.resource.data.department == resource.data.department
        && request.resource.data.status == resource.data.status
        && request.resource.data.authUids is list
        && request.auth.uid in request.resource.data.authUids;
    }

    match /employees/{employeeId} {
      allow create: if creatorAtLeast(6) || actorAtLeast(6);
      allow get, list: if signedIn();
      allow update: if loginClaim() || active(employeeId) || actorAtLeast(6) || creatorAtLeast(6);
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if signedIn();
      allow create: if atLeast(request.resource.data.createdByEmployeeId, 4);
      allow update: if active(request.resource.data.updatedByEmployeeId)
        || active(resource.data.assignedToEmployeeId)
        || atLeast(request.resource.data.updatedByEmployeeId, 4);
      allow delete: if false;
    }

    match /tickets/{ticketId} {
      allow read: if signedIn();
      allow create: if active(request.resource.data.createdByEmployeeId);
      allow update: if active(request.resource.data.updatedByEmployeeId)
        || active(resource.data.createdByEmployeeId)
        || atLeast(request.resource.data.updatedByEmployeeId, 6);
      allow delete: if false;
    }

    match /iaCases/{caseId} {
      allow read: if signedIn();
      allow create: if atLeast(request.resource.data.createdByEmployeeId, 4);
      allow update: if atLeast(request.resource.data.updatedByEmployeeId, 4)
        || active(resource.data.assignedToEmployeeId)
        || active(resource.data.createdByEmployeeId);
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }
  }
}
